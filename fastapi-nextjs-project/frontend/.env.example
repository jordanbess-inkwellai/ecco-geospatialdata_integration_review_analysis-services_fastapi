NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Feature flags
NEXT_PUBLIC_AI_ENABLED=false
NEXT_PUBLIC_QUERYBOOK_ENABLED=false
NEXT_PUBLIC_DOCETL_ENABLED=false

